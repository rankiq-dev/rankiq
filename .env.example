# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/rankiq

# ── Auth (Auth.js / NextAuth) ─────────────────────────────
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ── Google OAuth (for Auth + Search Console) ─────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── AI Provider ───────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── LLM Tracing (LangSmith) ──────────────────────────────
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=rankiq-dev

# ── Redis (BullMQ job queue) ──────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Payments (Stripe) ─────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_ID_GROWTH=
STRIPE_PRICE_ID_AGENCY=

# ── Email (Resend) ────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=hello@rankiq.com

# ── PageSpeed Insights API (optional — avoids 429 rate limits) ──────────
# Get a free key at https://console.cloud.google.com → enable PageSpeed Insights API
PAGESPEED_API_KEY=

# ── Firecrawl (optional — hosted crawl fallback for JS-heavy / bot-blocked sites) ──
# Get a free-tier key at https://firecrawl.dev — used automatically when the
# static Cheerio crawler returns 0 pages, before falling back to local Playwright.
FIRECRAWL_API_KEY=

# ── App ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
