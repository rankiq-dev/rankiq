    "drizzle-kit": "^0.31.1",
    "eslint": "^9.27.0",
    "eslint-config-next": "15.5.19",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.12",
    "tailwindcss": "^4.1.8",
    "tsx": "^4.19.4",
