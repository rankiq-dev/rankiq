    "js-yaml": "^5.1.0",
    "lucide-react": "^0.515.0",
    "next": "15.5.19",
    "next-auth": "^5.0.0-beta.25",
    "pino": "^9.7.0",
    "pino-pretty": "^13.0.0",
    "playwright": "^1.52.0",
    "postgres": "^3.4.5",
    "react": "19.1.0",
